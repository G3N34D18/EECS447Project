@page "/attendees/delete/{id:int}"
@rendermode RenderMode.InteractiveServer 
@using ArenaSync.Web.Models
@inject ArenaSync.Web.Services.IAttendeeService AttendeeService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Attendees &gt; Delete Attendee</div>
    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Delete Attendee</h1>
            <p class="arena-page-subtitle">Review the Attendee before removing it from the system.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading attendee...</div>
            </div>
        </div>
    }
    else if (attendee is null)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">Attendee not found</div>
            <p class="arena-empty-text">The requested attendee could not be loaded.</p>
            <a class="arena-primary-btn" href="/attendees">Back to Attendees</a>
        </div>
    }
    else
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-form-section-title">Are you sure you want to delete this attendee?</div>
            <p class="arena-muted">This action cannot be undone.</p>

            <div class="arena-summary-box">
                <div class="arena-entity-title">@attendee.Name</div>
                <div class="arena-muted">@attendee.Email</div>
                <div class="arena-muted">@attendee.Phone</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }

            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/attendees">Cancel</a>
                <button class="arena-danger-btn" @onclick="DeleteAttendeeAsync">Delete Attendee</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Attendee? attendee;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        attendee = await AttendeeService.GetAttendeeByIdAsync(Id);
        isLoading = false;
    }

    private async Task DeleteAttendeeAsync()
    {
        var deleted = await AttendeeService.DeleteAttendeeAsync(Id);
        if (!deleted)
        {
            errorMessage = "Attendee could not be found.";
            return;
        }

        Navigation.NavigateTo("/attendees");
    }
}
