@page "/venues/create"
@using ArenaSync.Web.Dtos
@using ArenaSync.Web.Models
@inject ArenaSync.Web.Services.IVenueService VenueService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Venues &gt; Add Venue</div>
    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Add Venue</h1>
            <p class="arena-page-subtitle">Enter the details for the new venue.</p>
        </div>
    </div>

    <div class="arena-card arena-form-card">
        <EditForm Model="form" OnValidSubmit="HandleSubmitAsync" FormName="venue-create-form">
            <DataAnnotationsValidator />

            <div class="arena-form-section-title">Venue Details</div>

            <div class="mb-3">
                <label class="arena-label">Venue Name</label>
                <InputText @bind-Value="form.Name" class="arena-input" />
                <ValidationMessage For="() => form.Name" />
            </div>

            <div class="mb-3">
                <label class="arena-label">Address</label>
                <InputText @bind-Value="form.Address" class="arena-input" />
                <ValidationMessage For="() => form.Address" />
            </div>

            <div class="mb-3">
                <label class="arena-label">Capacity</label>
                <InputNumber @bind-Value="form.Capacity" class="arena-input" />
                <ValidationMessage For="() => form.Capacity" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }

            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/venues">Cancel</a>
                <button type="submit" class="arena-primary-btn">Save Venue</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private VenueFormModel form { get; set; } = new();

    private string? errorMessage;

    private async Task HandleSubmitAsync()
    {
        try
        {
            var venue = new Venue
            {
                Name = form.Name,
                Address = form.Address,
                Capacity = form.Capacity
            };

            await VenueService.CreateVenueAsync(venue);
            Navigation.NavigateTo("/venues");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}