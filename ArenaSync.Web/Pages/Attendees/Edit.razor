@page "/attendees/edit/{id:int}"
@using ArenaSync.Web.Dtos
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@inject AttendeeService AttendeeService
@inject NavigationManager Navigation

@code {
    [Parameter] public int id { get; set; }

    private AttendeeFormModel? attendeeForm;
    private Attendee? existingAttendee;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        existingAttendee = await AttendeeService.GetAttendeeByIdAsync(id);

        if (existingAttendee != null)
        {
            attendeeForm = new AttendeeFormModel
            {
                Name = existingAttendee.Name,
                Email = existingAttendee.Email,
                Phone = existingAttendee.Phone
            };
        }
    }

    private async Task HandleSubmit()
    {
        if (existingAttendee == null || attendeeForm == null)
            return;

        existingAttendee.Name = attendeeForm.Name;
        existingAttendee.Email = attendeeForm.Email;
        existingAttendee.Phone = attendeeForm.Phone;

        var success = await AttendeeService.UpdateAttendeeAsync(existingAttendee);

        if (!success)
        {
            errorMessage = "An attendee with this email already exists.";
            return;
        }

        Navigation.NavigateTo("/attendees");
    }
}
