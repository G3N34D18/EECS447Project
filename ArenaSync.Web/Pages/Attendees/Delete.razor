@page "/attendees/delete/{id:int}"
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@inject AttendeeService AttendeeService
@inject NavigationManager Navigation

@code {
    [Parameter] public int id { get; set; }

    private Attendee? attendee;

    protected override async Task OnInitializedAsync()
    {
        attendee = await AttendeeService.GetAttendeeByIdAsync(id);
    }

    private async Task DeleteAttendee()
    {
        await AttendeeService.DeleteAttendeeAsync(id);
        Navigation.NavigateTo("/attendees");
    }
}
