@page "/teams/delete/{id:int}"
@rendermode RenderMode.InteractiveServer 
@using ArenaSync.Web.Models 
@inject ArenaSync.Web.Services.ITeamService TeamService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">teams &gt; Delete team</div>
    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Delete team</h1>
            <p class="arena-page-subtitle">Review the team before removing it from the system.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading team...</div>
            </div>
        </div>
    }
    else if (team is null)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">team not found</div>
            <p class="arena-empty-text">The requested team could not be loaded.</p>
            <a class="arena-primary-btn" href="/teams">Back to teams</a>
        </div>
    }
    else
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-form-section-title">Are you sure you want to delete this team?</div>
            <p class="arena-muted">This action cannot be undone.</p>

            <div class="arena-summary-box">
                <div class="arena-entity-title">@team.Name</div>
                <div class="arena-muted">@team.Manager</div>
                <div class="arena-muted">@team.Email</div>
                <div class="arena-muted">@team.Phone</div>
                <div class="arena-muted">@team.PlayerCount</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }

            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/teams">Cancel</a>
                <button class="arena-danger-btn" @onclick="DeleteTeamAsync">Delete team</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Team? team;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        team = await TeamService.GetTeamByIdAsync(Id);
        isLoading = false;
    }

    private async Task DeleteTeamAsync()
    {
        var deleted = await TeamService.DeleteTeamAsync(Id);
        if (!deleted)
        {
            errorMessage = "Team could not be deleted. Remove event registrations, assignments, and pending requests first.";
            return;
        }

        Navigation.NavigateTo("/teams");
    }
}
