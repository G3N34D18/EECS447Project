@page "/teams/edit/{Id:int}"
@using ArenaSync.Web.Dtos
@using ArenaSync.Web.Models
@using ArenaSync.Web.Pages.Events
@using ArenaSync.Web.Services
@inject ArenaSync.Web.Services.ITeamService TeamService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Teams &gt; Edit Team</div>

    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Edit Team</h1>
            <p class="arena-page-subtitle">Update Team details below.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-form-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading team...</div>
            </div>
        </div>
    }
    else if (teamNotFound)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">Team not found</div>
            <p class="arena-empty-text">The requested team could not be loaded.</p>
            <a class="arena-primary-btn" href="/teams">Back to Teams</a>
        </div>
    }
    else
    {
        <div class="arena-card arena-form-card">
            <EditForm Model="form" OnValidSubmit="HandleSubmitAsync" FormName="team-edit-form">
                <DataAnnotationsValidator />

                <div class="arena-form-section-title">Team Information</div>

                <div class="mb-3">
                    <label class="arena-label">Name</label>
                    <InputText @bind-Value="form.Name" class="arena-input" />
                    <ValidationMessage For="@(() => form.Name)" />
                </div>

                <div class="mb-3">
                    <label class="arena-label">Manager</label>
                    <InputText @bind-Value="form.Manager" class="arena-input" />
                    <ValidationMessage For="@(() => form.Manager)" />
                </div>

                <div class="mb-3">
                    <label class="arena-label">Email</label>
                    <InputText @bind-Value="form.Email" class="arena-input" />
                    <ValidationMessage For="@(() => form.Email)" />
                </div>

                <div class="mb-3">
                    <label class="arena-label">Phone</label>
                    <InputText @bind-Value="form.Phone" class="arena-input" />
                    <ValidationMessage For="@(() => form.Phone)" />
                </div>

                <div class="mb-3">
                    <label class="arena-label">Player Count</label>
                    <InputNumber @bind-Value="form.PlayerCount" class="arena-input" />
                    <ValidationMessage For="() => form.PlayerCount" />
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="arena-warning">@errorMessage</div>
                }

                <div class="arena-form-actions">
                    <a class="arena-secondary-btn" href="/teams">Cancel</a>
                    <button type="submit" class="arena-primary-btn">Save Changes</button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromForm]
    private TeamFormModel form { get; set; } = new TeamFormModel();

    private bool isLoading = true;
    private bool teamNotFound;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var team = await TeamService.GetTeamByIdAsync(Id);
        if (team is null)
        {
            teamNotFound = true;
        }
        else if (string.IsNullOrWhiteSpace(form.Name) && string.IsNullOrWhiteSpace(form.Manager) && string.IsNullOrWhiteSpace(form.Email) && string.IsNullOrWhiteSpace(form.Phone) && form.PlayerCount == 0)
        {
            form.Name = team.Name;
            form.Manager = team.Manager;
            form.Email = team.Email;
            form.Phone = team.Phone;
            form.PlayerCount = team.PlayerCount;
        }

        isLoading = false;
    }

    private async Task HandleSubmitAsync()
    {
        try
        {
            var team = new Team
            {
                Id = Id,
                Name = form.Name,
                Manager = form.Manager,
                Email = form.Email,
                Phone = form.Phone,
                PlayerCount = form.PlayerCount
            };

            var result = await TeamService.UpdateTeamAsync(team);
            if (result is null)
            {
                teamNotFound = true;
                return;
            }

            Navigation.NavigateTo("/teams");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}