@page "/teams/create"
@using ArenaSync.Web.Dtos
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@inject TeamService TeamService
@inject NavigationManager Navigation

@code {
    private TeamFormModel teamForm = new();
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        // Map DTO → Entity
        var team = new Team
        {
            Name = teamForm.Name,
            Manager = teamForm.Manager,
            Email = teamForm.Email,
            Phone = teamForm.Phone,
            PlayerCount = teamForm.PlayerCount
        };

        var success = await TeamService.CreateTeamAsync(team);

        if (!success)
        {
            errorMessage = "A team with this name already exists.";
            return;
        }

        Navigation.NavigateTo("/teams");
    }
}
