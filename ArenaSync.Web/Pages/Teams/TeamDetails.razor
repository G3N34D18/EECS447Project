@page "/teams/details/{TeamId:int}"
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@rendermode RenderMode.InteractiveServer
@inject ITeamService TeamService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Teams &gt; Details</div>

    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">@team?.Name</h1>
            <p class="arena-page-subtitle">Team information, assignments, and requests</p>
        </div>
        <div class="arena-actions">
            <a class="arena-primary-btn" href="/teams/assign/@TeamId">Assign to Event</a>
            <a class="arena-outline-btn" href="/teams/request-reassignment/@TeamId">Request Reassignment</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-form-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading team...</div>
            </div>
        </div>
    }
    else if (teamNotFound)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">Team not found</div>
            <p class="arena-empty-text">The requested team could not be loaded.</p>
            <a class="arena-primary-btn" href="/teams">Back to Teams</a>
        </div>
    }
    else
    {
        <!-- Team Info -->
        <div class="arena-card arena-form-card">
            <div class="arena-form-section-title">Team Information</div>

            <div class="arena-info-row">
                <span class="arena-info-label">Name</span>
                <span class="arena-info-value">@team!.Name</span>
            </div>
            <div class="arena-info-row">
                <span class="arena-info-label">Manager</span>
                <span class="arena-info-value">@team.Manager</span>
            </div>
            <div class="arena-info-row">
                <span class="arena-info-label">Email</span>
                <span class="arena-info-value">@team.Email</span>
            </div>
            <div class="arena-info-row">
                <span class="arena-info-label">Phone</span>
                <span class="arena-info-value">@team.Phone</span>
            </div>
            <div class="arena-info-row">
                <span class="arena-info-label">Players</span>
                <span class="arena-info-value">@team.PlayerCount</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(actionMessage))
        {
            <div class="arena-warning">@actionMessage</div>
        }

        <!-- Event Registrations -->
        <div class="arena-card arena-table-card">
            <div class="arena-form-section-title">Event Registrations</div>

            @if (!team.ParticipatesIn.Any())
            {
                <div class="arena-empty-state">
                    <div class="arena-empty-title">No Event Registrations</div>
                    <p class="arena-empty-text">This team is not registered for any events.</p>
                    <a class="arena-primary-btn" href="/teams/assign/@TeamId">Assign to Event</a>
                </div>
            }
            else
            {
                <table class="arena-table">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Locker</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var participation in team.ParticipatesIn.OrderBy(p => p.Event?.StartTime))
                        {
                            var eventAssignment = team.Assignments.FirstOrDefault(a => a.EventId == participation.EventId);
                            var eventEntity = participation.Event;
                            <tr>
                                <td>
                                    <div class="arena-entity-title">@eventEntity?.Name</div>
                                    <div class="arena-muted">@eventEntity?.Venue?.Name</div>
                                </td>
                                <td>@eventEntity?.StartTime.ToShortDateString()</td>
                                <td>
                                    @if (eventAssignment is null)
                                    {
                                        <span class="arena-muted">No locker assigned</span>
                                    }
                                    else
                                    {
                                        <span>Room @eventAssignment.LockerRoom.RoomNumber</span>
                                    }
                                </td>
                                <td>
                                    <div class="arena-table-actions">
                                        <a class="arena-table-action" href="/teams/request-reassignment/@TeamId">Request Reassignment</a>
                                        <button type="button"
                                                class="arena-table-action arena-table-action-danger"
                                                disabled="@(!CanResign(eventEntity))"
                                                title="@GetResignTitle(eventEntity)"
                                                @onclick="() => ResignAsync(participation.EventId)">
                                            Resign
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        @if (team.ParticipatesIn.Any())
        {
            <div class="arena-card arena-form-card">
                <div class="arena-form-section-title">Request Late Resignation</div>
                <p class="arena-muted">Use this when a team needs to leave an event inside the 48-hour resignation window.</p>

                <div class="arena-form-grid">
                    <div class="mb-3">
                        <label class="arena-label">Event</label>
                        <select class="arena-select" @bind="selectedResignationEventId">
                            <option value="0">Choose an event</option>
                            @foreach (var participation in team.ParticipatesIn.OrderBy(p => p.Event?.StartTime))
                            {
                                <option value="@participation.EventId">@participation.Event?.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="arena-label">Explanation</label>
                        <textarea class="arena-textarea" @bind="resignationReason"></textarea>
                    </div>
                </div>

                <div class="arena-form-actions">
                    <button type="button" class="arena-primary-btn" @onclick="SubmitLateResignationAsync">Submit Resignation Request</button>
                </div>
            </div>
        }

        <!-- Pending Event Requests -->
        <div class="arena-card arena-table-card">
            <div class="arena-form-section-title">Pending Event Requests</div>

            @if (!pendingRequests.Any())
            {
                <div class="arena-empty-state">
                    <div class="arena-empty-title">No Pending Requests</div>
                    <p class="arena-empty-text">There are no pending event requests for this team.</p>
                </div>
            }
            else
            {
                <table class="arena-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Source Event</th>
                            <th>Target Event</th>
                            <th>Reason</th>
                            <th>Submitted</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in pendingRequests)
                        {
                            <tr>
                                <td>@FormatRequestType(r.Type)</td>
                                <td>@(r.SourceEvent?.Name ?? "-")</td>
                                <td>@(r.TargetEvent?.Name ?? "-")</td>
                                <td>@r.Reason</td>
                                <td>@r.SubmittedAt.ToShortDateString()</td>
                                <td>
                                    <span class="arena-badge arena-badge-warning">@r.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="arena-form-actions">
                    <a class="arena-outline-btn" href="/admin/pending-requests">Review All Pending Requests</a>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int TeamId { get; set; }

    private Team? team;
    private List<TeamEventRequest> pendingRequests = new();
    private int selectedResignationEventId;
    private string resignationReason = string.Empty;
    private bool isLoading = true;
    private bool teamNotFound;
    private string? actionMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        team = await TeamService.GetTeamByIdAsync(TeamId);

        if (team is null)
        {
            teamNotFound = true;
        }
        else
        {
            pendingRequests = await TeamService.GetPendingRequestsForTeamAsync(TeamId);
        }

        isLoading = false;
    }

    private async Task ResignAsync(int eventId)
    {
        actionMessage = null;
        var result = await TeamService.ResignTeamFromEventAsync(TeamId, eventId);
        actionMessage = result.Message;
        await OnParametersSetAsync();
    }

    private async Task SubmitLateResignationAsync()
    {
        actionMessage = null;
        if (selectedResignationEventId == 0)
        {
            actionMessage = "Choose an event for the resignation request.";
            return;
        }

        var result = await TeamService.SubmitLateResignationRequestAsync(TeamId, selectedResignationEventId, resignationReason);
        actionMessage = result.Message;
        if (result.Succeeded)
        {
            selectedResignationEventId = 0;
            resignationReason = string.Empty;
        }

        await OnParametersSetAsync();
    }

    private static bool CanResign(Event? eventEntity)
    {
        return eventEntity is not null && eventEntity.StartTime > DateTime.Now.AddHours(48);
    }

    private static string GetResignTitle(Event? eventEntity)
    {
        return CanResign(eventEntity)
            ? "Resign from this event"
            : "Use a late resignation request inside the 48-hour window.";
    }

    private static string FormatRequestType(TeamEventRequestType type)
    {
        return type switch
        {
            TeamEventRequestType.Reassignment => "Reassignment",
            TeamEventRequestType.LateResignation => "Late Resignation",
            TeamEventRequestType.OverlapParticipation => "Overlap Participation",
            _ => type.ToString()
        };
    }
}
