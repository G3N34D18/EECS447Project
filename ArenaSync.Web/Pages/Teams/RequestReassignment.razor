@page "/teams/request-reassignment/{TeamId:int}"
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@rendermode RenderMode.InteractiveServer
@inject ITeamService TeamService
@inject IEventService EventService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Teams &gt; Request Reassignment</div>

    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Request Event Reassignment</h1>
            <p class="arena-page-subtitle">Submit a reassignment request for admin review.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-form-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading team...</div>
            </div>
        </div>
    }
    else if (teamNotFound)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">Team not found</div>
            <p class="arena-empty-text">The requested team could not be loaded.</p>
            <a class="arena-primary-btn" href="/teams">Back to Teams</a>
        </div>
    }
    else if (submitted)
    {
        <div class="arena-card arena-form-card">
            <div class="arena-empty-state">
                <div class="arena-empty-title">Request Submitted</div>
                <p class="arena-empty-text">
                    The reassignment request for <strong>@team!.Name</strong> has been sent to an admin for review.
                </p>
                <a class="arena-primary-btn" href="/teams/details/@TeamId">Back to Team</a>
            </div>
        </div>
    }
    else
    {
        <div class="arena-card arena-form-card">
            <div class="arena-form-section-title">Current Registrations</div>
            @if (team!.ParticipatesIn.Count == 0)
            {
                <p class="arena-muted">This team is not currently registered for any event.</p>
                <div class="arena-warning">A team must be registered for an event before it can request reassignment.</div>
            }
            else
            {
                <div class="arena-summary-box">
                    @foreach (var p in team.ParticipatesIn.OrderBy(p => p.Event?.StartTime))
                    {
                        <div class="arena-entity-title">@p.Event?.Name</div>
                        <div class="arena-muted">@p.Event?.StartTime.ToShortDateString()</div>
                    }
                </div>

                <div class="arena-form-section-title" style="margin-top:1.5rem;">Reassignment Request</div>

                <div class="arena-form-grid">
                    <div class="mb-3">
                        <label class="arena-label">Current Event</label>
                        <select class="arena-select" @bind="selectedSourceEventId">
                            <option value="0">Choose current event</option>
                            @foreach (var participation in team.ParticipatesIn.OrderBy(p => p.Event?.StartTime))
                            {
                                <option value="@participation.EventId">@participation.Event?.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="arena-label">Requested Event</label>
                        <select class="arena-select" @bind="selectedTargetEventId">
                            <option value="0">Choose requested event</option>
                            @foreach (var ev in availableEvents)
                            {
                                <option value="@ev.Id">@ev.Name - @ev.StartTime.ToShortDateString()</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="arena-label">Reason for Reassignment</label>
                    <textarea class="arena-input" rows="3"
                              @bind="reason"
                              placeholder="Briefly explain why this reassignment is needed..."></textarea>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }

            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/teams/details/@TeamId">Cancel</a>
                @if (team.ParticipatesIn.Any())
                {
                    <button class="arena-primary-btn" @onclick="SubmitRequestAsync">Submit Request</button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int TeamId { get; set; }

    private Team? team;
    private List<Event> availableEvents = new();
    private int selectedSourceEventId;
    private int selectedTargetEventId;
    private string reason = string.Empty;
    private bool isLoading = true;
    private bool teamNotFound;
    private bool submitted;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        team = await TeamService.GetTeamByIdAsync(TeamId);

        if (team is null)
        {
            teamNotFound = true;
        }
        else
        {
            var allEvents = await EventService.GetAllEventsAsync();
            var assignedEventIds = team.ParticipatesIn.Select(p => p.EventId).ToHashSet();
            availableEvents = allEvents.Where(e => !assignedEventIds.Contains(e.Id)).ToList();
        }

        isLoading = false;
    }

    private async Task SubmitRequestAsync()
    {
        errorMessage = null;

        if (selectedSourceEventId == 0)
        {
            errorMessage = "Please select the current event.";
            return;
        }

        if (selectedTargetEventId == 0)
        {
            errorMessage = "Please select the requested event.";
            return;
        }

        var result = await TeamService.SubmitReassignmentRequestAsync(
            TeamId, selectedSourceEventId, selectedTargetEventId, reason);

        if (!result.Succeeded)
        {
            errorMessage = result.Message;
            return;
        }

        submitted = true;
    }
}
