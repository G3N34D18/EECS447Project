        </NavLink>

        <NavLink class="arena-nav-link" href="/teams">
            <i class="bi bi-people-fill arena-nav-icon"></i>
            <span>Teams</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/admin/pending-requests">
            <i class="bi bi-bell-fill arena-nav-icon"></i>
            <span>Requests</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/attendees">
            <i class="bi bi-person-lines-fill arena-nav-icon"></i>
            <span>Attendees</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/vendors">
            <i class="bi bi-shop-window arena-nav-icon"></i>
            <span>Vendors</span>
        </NavLink>



    </nav>

    <div class="arena-sidebar-footer">
        <a class="arena-nav-link arena-nav-link-muted" href="javascript:void(0)">
            <i class="bi bi-gear-fill arena-nav-icon"></i>
            <span>Settings</span>
        </a>
        <a class="arena-nav-link arena-nav-link-muted" href="javascript:void(0)">
            <i