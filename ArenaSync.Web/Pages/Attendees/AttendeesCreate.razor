@page "/attendees/create"
@using ArenaSync.Web.Dtos
@using ArenaSync.Web.Models
@using ArenaSync.Web.Services
@rendermode RenderMode.InteractiveServer 
@inject ArenaSync.Web.Services.IAttendeeService AttendeeService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Attendees &gt; Add Attendee</div>
    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Add Attendee</h1>
            <p class="arena-page-subtitle">Enter the new attendee details below.</p>
        </div>
        <a class="arena-primary-btn" href="/attendees">Back to Attendees</a>
    </div>

    <div class="arena-card arena-form-card">
        <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="attendee-create-form">
            <DataAnnotationsValidator />

            <div class="arena-form-section-title">Attendee Information</div>
            <div class="mb-3">
                <label class="arena-label">Attendee Name</label>
                <InputText @bind-Value="form.Name" class="arena-input" />
                <ValidationMessage For="@(() => form.Name)" />
            </div>

            <div class="mb-3">
                <label class="arena-label">Attendee Email</label>
                <InputText @bind-Value="form.Email" class="arena-input" />
                <ValidationMessage For="@(() => form.Email)" />
            </div>

            <div class="mb-3">
                <label class="arena-label">Attendee Phone</label>
                <InputText @bind-Value="form.Phone" class="arena-input" />
                <ValidationMessage For="@(() => form.Phone)" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }
            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/attendees">Cancel</a>
                <button type="submit" class="arena-primary-btn">Create Attendee</button>
            </div>
        </EditForm>
    </div>
</div>    

@code {
    [SupplyParameterFromForm]
    private AttendeeFormModel form { get; set; } = new();
    private string? errorMessage;
    protected override async Task OnInitializedAsync()
    {
        // Initialization logic if needed
    }

    private async Task HandleSubmit()
    {
        try {
            var attendee = new Attendee
            {
                Name = form.Name,
                Email = form.Email,
                Phone = form.Phone
            };
            await AttendeeService.CreateAttendeeAsync(attendee);
            Navigation.NavigateTo("/attendees");
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while creating the attendee. Please try again.";
            Console.Error.WriteLine($"Error creating attendee: {ex.Message}");
        }
    }
}
