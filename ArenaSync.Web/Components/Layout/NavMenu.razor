@namespace ArenaSync.Web.Components.Layout
<div class="arena-sidebar">
      
   <div class="arena-brand">
        <img src="images/arenasync-mark.png" alt="ArenaSync logo" class="arena-brand-logo" />

        <div class="arena-brand-text">
            <div class="arena-brand-title">ArenaSync</div>
            <div class="arena-brand-subtitle">Operations Console</div>
        </div>
    </div>

    <nav class="arena-nav">
        <NavLink class="arena-nav-link" href="/" Match="NavLinkMatch.All">
            <span class="arena-nav-icon">⌂</span>
            <span>Dashboard</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/events">
            <span class="arena-nav-icon">▣</span>
            <span>Events</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/reports">
            <span class="arena-nav-icon">▤</span>
            <span>Reports</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/venues">
            <span class="arena-nav-icon">⌖</span>
            <span>Venues</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/teams">
            <span class="arena-nav-icon">⚭</span>
            <span>Teams</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/admin/pending-requests">
            <span class="arena-nav-icon">!</span>
            <span>Requests</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/attendees">
            <span class="arena-nav-icon">○</span>
            <span>Attendees</span>
        </NavLink>

        <NavLink class="arena-nav-link" href="/vendors">
            <span class="arena-nav-icon">◇</span>
            <span>Vendors</span>
        </NavLink>



    </nav>

    <div class="arena-sidebar-footer">
        <a class="arena-nav-link arena-nav-link-muted" href="javascript:void(0)">
            <span class="arena-nav-icon">⚙</span>
            <span>Settings</span>
        </a>
        <a class="arena-nav-link arena-nav-link-muted" href="javascript:void(0)">
            <span class="arena-nav-icon">?</span>
            <span>Help</span>
        </a>
    </div>
</div>
