# ArenaSync environment variable template
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# SQL Server connection string
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=ArenaSyncDb;Trusted_Connection=True;TrustServerCertificate=True;

# ASP.NET Core environment (Development | Staging | Production)
ASPNETCORE_ENVIRONMENT=Development

# Docker Compose: SQL Server SA password
SA_PASSWORD=ArenaSync_Dev123!
