<div class="arena-page-header">
    <div>
        <div class="arena-breadcrumb">@Breadcrumb</div>
        <h1 class="arena-page-title">@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p class="arena-page-subtitle">@Subtitle</p>
        }
    </div>
    <div class="arena-actions">
        @Actions
        @if (!string.IsNullOrWhiteSpace(ExportHref))
        {
            <a class="arena-outline-btn" href="@ExportHref">Export</a>
        }
        @if (!string.IsNullOrWhiteSpace(BackHref))
        {
            <a class="arena-primary-btn" href="@BackHref">@BackLabel</a>
        }
    </div>
</div>

@code {
    [Parameter] public string Breadcrumb { get; set; } = "Reports";
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? BackHref { get; set; } = "/reports";
    [Parameter] public string BackLabel { get; set; } = "Back to Reports";
    [Parameter] public string? ExportHref { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
