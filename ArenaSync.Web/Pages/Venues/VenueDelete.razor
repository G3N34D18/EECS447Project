@page "/venues/delete/{Id:int}"
@rendermode RenderMode.InteractiveServer
@using ArenaSync.Web.Models
@inject ArenaSync.Web.Services.IVenueService VenueService
@inject NavigationManager Navigation

<div class="arena-page">
    <div class="arena-breadcrumb">Venues &gt; Delete Venue</div>
    <div class="arena-page-header">
        <div>
            <h1 class="arena-page-title">Delete Venue</h1>
            <p class="arena-page-subtitle">Review the venue before removing it from the system.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-state">
                <div class="arena-empty-logo"></div>
                <div class="arena-empty-title">Loading venue...</div>
            </div>
        </div>
    }
    else if (venue is null)
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-empty-title">Venue not found</div>
            <p class="arena-empty-text">The requested venue could not be loaded.</p>
            <a class="arena-primary-btn" href="/venues">Back to Venues</a>
        </div>
    }
    else
    {
        <div class="arena-card arena-delete-card">
            <div class="arena-form-section-title">Are you sure you want to delete this venue?</div>
            <p class="arena-muted">This action cannot be undone.</p>

            <div class="arena-summary-box">
                <div class="arena-entity-title">@venue.Name</div>
                <div class="arena-muted">@venue.Address</div>
                <div class="arena-muted">Capacity: @venue.Capacity.ToString("N0")</div>
                <div class="arena-muted">Scheduled events: @(venue.Events?.Count ?? 0)</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="arena-warning">@errorMessage</div>
            }

            <div class="arena-form-actions">
                <a class="arena-secondary-btn" href="/venues">Cancel</a>
                <button class="arena-danger-btn" @onclick="DeleteVenueAsync">Delete Venue</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Venue? venue;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        venue = await VenueService.GetVenueByIdAsync(Id);
        isLoading = false;
    }

    private async Task DeleteVenueAsync()
    {
        try
        {
            var deleted = await VenueService.DeleteVenueAsync(Id);
            if (!deleted)
            {
                errorMessage = "Venue could not be deleted. Remove related events, locker rooms, and booths first.";
                return;
            }

            Navigation.NavigateTo("/venues");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
