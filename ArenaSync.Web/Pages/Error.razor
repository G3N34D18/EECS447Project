@page "/Error"
@using System.Diagnostics
@inject ILogger<Error> Logger
@inject IWebHostEnvironment Env

<PageTitle>Error — ArenaSync</PageTitle>

<div class="error-page">
    <div class="error-card">
        <h1 class="text-danger">Something went wrong</h1>
        <p class="lead">
            We're sorry — an unexpected error occurred while processing your request.
            Our team has been notified.
        </p>

        @if (ShowRequestId)
        {
            <p class="text-muted small">
                <strong>Reference ID:</strong> <code>@RequestId</code>
            </p>
        }

        @if (Env.IsDevelopment() && _exceptionMessage is not null)
        {
            <details class="mt-3">
                <summary class="text-warning">Developer details (Development only)</summary>
                <pre class="error-detail mt-2">@_exceptionMessage</pre>
            </details>
        }

        <div class="mt-4">
            <a href="/" class="btn btn-primary">Return to Dashboard</a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);
    private string? _exceptionMessage;

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;

        // Log and capture the exception for dev display
        var exceptionFeature = HttpContext?.Features.Get<Microsoft.AspNetCore.Diagnostics.IExceptionHandlerFeature>();
        if (exceptionFeature?.Error is { } ex)
        {
            Logger.LogError(ex, "Error page rendered for request {RequestId}", RequestId);
            _exceptionMessage = Env.IsDevelopment() ? ex.ToString() : null;
        }
    }
}
